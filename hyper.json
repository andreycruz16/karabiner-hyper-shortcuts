    {
      "description": "Hyper + D → Insert current date and time (YYYY-MM-DD_HH-MM-SS)",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "d",
            "modifiers": {
              "mandatory": [
                "left_control",
                "left_option",
                "left_shift",
                "left_command"
              ]
            }
          },
          "to": [
            {
              "shell_command": "date '+%Y-%m-%d_%H-%M-%S' | pbcopy"
            },
            {
              "key_code": "v",
              "modifiers": ["left_command"]
            }
          ]
        }
      ]
    },
    {
      "description": "Hyper + N → Open Notes",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "n",
            "modifiers": {
