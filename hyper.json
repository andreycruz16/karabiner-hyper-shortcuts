      ]
    },
    {
      "description": "Hyper + ` → Open System Settings",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "grave_accent_and_tilde",
            "modifiers": {
              "mandatory": [
                "left_control",
                "left_option",
                "left_shift",
                "left_command"
