    {
      "description": "Hyper + I → Insert UUID",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "i",
            "modifiers": {
              "mandatory": [
                "left_control",
                "left_option",
                "left_shift",
                "left_command"
              ]
            }
          },
          "to": [
            {
              "shell_command": "uuidgen | tr 'A-Z' 'a-z' | pbcopy"
            },
            {
              "key_code": "v",
              "modifiers": ["left_command"]
            }
          ]
        }
      ]
    },
