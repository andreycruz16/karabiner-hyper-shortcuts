{
  "title": "Hyper shortcuts",
  "rules": [
    {
      "description": "Hyper + 1 → Open Google",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "1",
            "modifiers": {
              "mandatory": [
                "left_control",
                "left_option",
                "left_shift",
                "left_command"
              ]
            }
          },
          "to": [
            {
              "shell_command": "open https://www.google.com"
            }
          ]
        }
      ]
    },
    {
      "description": "Hyper + 2 → Open ChatGPT",
      "manipulators": [
        {
          "type": "basic",
