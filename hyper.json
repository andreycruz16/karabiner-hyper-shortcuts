    {
      "description": "Hyper + F4 → Search google highlighted text",
      "manipulators": [
      {
        "type": "basic",
        "from": {
        "key_code": "f4",
        "modifiers": {
          "mandatory": [
          "left_control",
          "left_option",
          "left_shift",
          "left_command"
          ]
        }
        },
        "to": [
        {
          "key_code": "c",
          "modifiers": ["left_command"]
        },
        {
          "shell_command": "open \"https://www.google.com/search?q=$(pbpaste | sed 's/ /+/g')\""
